# 环境变量配置示例
# 复制此文件为 .env.local 并填入实际值

# 阿里云API密钥（用于AI食谱生成）
ALIYUN_API_KEY=your_aliyun_api_key_here

# Supabase数据库配置
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# 可选：阿里云VL API端点（用于图片识别）
# ALIYUN_VL_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation

# 可选：阿里云文本生成API端点（用于食谱生成）
# ALIYUN_TEXT_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation